{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "DOM",
            "ES2020"
        ],
        "module": "ESNext",
        "moduleResolution": "Node",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "allowJs": true,
        "resolveJsonModule": true,
        "sourceMap": true
    },
    "include": [
        "./**/*"
    ],
    "exclude": [
        "./dist",
        "node_modules"
    ]
}